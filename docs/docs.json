{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "VidJutsu",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.svg",
  "api": {
    "baseUrl": "https://api.vidjutsu.ai",
    "auth": {
      "method": "bearer"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "features",
              "authentication",
              "credits-and-billing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Billing & Keys",
            "openapi": "https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json",
            "pages": [
              "GET /v1/pricing",
              "POST /v1/credits",
              "POST /v1/subscribe",
              "GET /v1/credits/status",
              "GET /v1/balance",
              "POST /v1/api_keys/rotate",
              "POST /v1/api_keys/recover",
              "GET /v1/info"
            ]
          },
          {
            "group": "Auth",
            "openapi": "https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json",
            "pages": [
              "POST /v1/auth/verify/request",
              "POST /v1/auth/verify/confirm"
            ]
          },
          {
            "group": "Intelligence",
            "openapi": "https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json",
            "pages": [
              "POST /v1/watch",
              "POST /v1/extract",
              "POST /v1/transcribe",
              "POST /v1/check",
              "POST /v1/overlay"
            ]
          },
          {
            "group": "Check Rules",
            "openapi": "https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json",
            "pages": [
              "GET /v1/check/rules",
              "PUT /v1/check/rules"
            ]
          },
          {
            "group": "Upload",
            "openapi": "https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json",
            "pages": [
              "POST /v1/upload",
              "POST /v1/upload/url"
            ]
          },
          {
            "group": "Assets",
            "openapi": "https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json",
            "pages": [
              "POST /v1/assets",
              "GET /v1/assets",
              "PUT /v1/assets",
              "DELETE /v1/assets"
            ]
          },
          {
            "group": "Accounts",
            "openapi": "https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json",
            "pages": [
              "POST /v1/accounts",
              "GET /v1/accounts",
              "PUT /v1/accounts",
              "DELETE /v1/accounts"
            ]
          },
          {
            "group": "Posts",
            "openapi": "https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json",
            "pages": [
              "POST /v1/posts",
              "GET /v1/posts",
              "PUT /v1/posts",
              "DELETE /v1/posts"
            ]
          },
          {
            "group": "References",
            "openapi": "https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json",
            "pages": [
              "POST /v1/references",
              "GET /v1/references",
              "PUT /v1/references",
              "DELETE /v1/references"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "cli/index",
              "cli/install",
              "cli/auth",
              "cli/watch",
              "cli/extract",
              "cli/transcribe",
              "cli/check",
              "cli/accounts",
              "cli/posts",
              "cli/upload",
              "cli/balance"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/tfcbot/vidjutsu-cli",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://vidjutsu.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/tfcbot/vidjutsu-cli"
    }
  }
}
