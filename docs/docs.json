{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "VidJutsu",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.svg",
  "api": {
    "baseUrl": "https://api.vidjutsu.ai",
    "auth": {
      "method": "bearer"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "features",
              "authentication",
              "credits-and-billing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://raw.githubusercontent.com/tfcbot/vidjutsu-openapi/main/openapi/spec.json",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Intelligence",
            "pages": [
              "api-reference/intelligence/watch",
              "api-reference/intelligence/extract",
              "api-reference/intelligence/transcribe",
              "api-reference/intelligence/check",
              "api-reference/intelligence/overlay"
            ]
          },
          {
            "group": "Check Rules",
            "pages": [
              "api-reference/check/rules-get",
              "api-reference/check/rules-update"
            ]
          },
          {
            "group": "Accounts",
            "pages": [
              "api-reference/accounts/create",
              "api-reference/accounts/update",
              "api-reference/accounts/list",
              "api-reference/accounts/delete"
            ]
          },
          {
            "group": "Posts",
            "pages": [
              "api-reference/posts/create",
              "api-reference/posts/update",
              "api-reference/posts/list",
              "api-reference/posts/delete"
            ]
          },
          {
            "group": "Assets",
            "pages": [
              "api-reference/assets/create",
              "api-reference/assets/update",
              "api-reference/assets/list",
              "api-reference/assets/delete"
            ]
          },
          {
            "group": "References",
            "pages": [
              "api-reference/references/create",
              "api-reference/references/update",
              "api-reference/references/list",
              "api-reference/references/delete"
            ]
          },
          {
            "group": "Upload",
            "pages": [
              "api-reference/upload/upload",
              "api-reference/upload/upload-url"
            ]
          },
          {
            "group": "Billing",
            "pages": [
              "api-reference/billing/credits",
              "api-reference/billing/credits-status",
              "api-reference/billing/subscribe",
              "api-reference/billing/info",
              "api-reference/billing/pricing",
              "api-reference/api-keys/balance",
              "api-reference/api-keys/rotate",
              "api-reference/api-keys/recover"
            ]
          },
          {
            "group": "Auth",
            "pages": [
              "api-reference/auth/verify-request",
              "api-reference/auth/verify-confirm"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "cli/index",
              "cli/install",
              "cli/auth",
              "cli/watch",
              "cli/extract",
              "cli/transcribe",
              "cli/check",
              "cli/accounts",
              "cli/posts",
              "cli/upload",
              "cli/balance"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/tfcbot/vidjutsu-cli",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://vidjutsu.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/tfcbot/vidjutsu-cli"
    }
  }
}
